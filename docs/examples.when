group lines10 = [
  "import { print } from \"console\";",
  "",
  "number add(number a, number b) { return a + b; }",
  "number square(number n) { return n * n; }",
  "",
  "print(\"add(3, 4)  = \", add(3, 4));",
  "print(\"square(5)  = \", square(5));",
  "",
  "// function 是一等类型: 装进变量再调用",
  "function op = add;",
  "print(\"op(10, 20) = \", op(10, 20));"
];
group colors10 = [cText, cDim, cText, cText, cDim, cText, cText, cDim, cDim, cText, cText];
group out10 = ["add(3, 4)  = 7", "square(5)  = 25", "op(10, 20) = 30"];
string src10 = "./playground.html?src=aW1wb3J0IHsgcHJpbnQgfSBmcm9tICJjb25zb2xlIjsKCm51bWJlciBhZGQobnVtYmVyIGEsIG51bWJlciBiKSB7IHJldHVybiBhICsgYjsgfQpudW1iZXIgc3F1YXJlKG51bWJlciBuKSB7IHJldHVybiBuICogbjsgfQoKcHJpbnQoImFkZCgzLCA0KSAgPSAiLCBhZGQoMywgNCkpOwpwcmludCgic3F1YXJlKDUpICA9ICIsIHNxdWFyZSg1KSk7CgovLyBmdW5jdGlvbiDmmK_kuIDnrYnnsbvlnos6IOijhei_m-WPmOmHj-WGjeiwg-eUqApmdW5jdGlvbiBvcCA9IGFkZDsKcHJpbnQoIm9wKDEwLCAyMCkgPSAiLCBvcCgxMCwgMjApKTs%3D";

// 模拟控制台卡片(container):标题 + 说明 + 终端外壳(三色圆点 + 文件名 + Playground 链接 +
// 代码 + 输出)。lines/colors/outs 三个 group 靠 each() 的索引对齐渲染,一张卡一份数据。
container FeatureCard(string title, string blurb, string filename, string srcHref, group lines, group colors, group outs) extends Column {
  gap: 4;
  Text(title) { size: 17; weight: bold; color: cText; }
  Text(blurb) { size: 13.5; color: cDim; marginTop: 4; marginBottom: 12; lineHeight: "1.6"; }
  Column {
    bg: cTerm; border: "1px solid " + cLine; radius: 12; overflow: "hidden"; shadow: "0 14px 36px rgba(0,0,0,.28)";
    Row {
      alignItems: "center"; gap: 7; pad: (9, 14); borderBottom: "1px solid " + cLine; bg: cBgDeep;
      Box { width: 10; height: 10; radius: 999; bg: "#ff5f57"; }
      Box { width: 10; height: 10; radius: 999; bg: "#febc2e"; }
      Box { width: 10; height: 10; radius: 999; bg: "#28c840"; }
      Text(filename) { font: fMono; size: 11; color: cDim; letterSpacing: "0.08em"; marginLeft: 6; }
      append(self, playRunLink(srcHref));
    }
    Column {
      pad: (14, 16); gap: 1;
      appendCodeLines(self, lines, colors);
    }
    Column {
      pad: (8, 16, 12, 16); borderTop: "1px solid " + cLine; bg: "#0f0d1a";
      Text("output · 真实运行结果") { font: fMono; size: 10; color: "#5c5480"; letterSpacing: "0.14em"; textTransform: "uppercase"; marginTop: 4; marginBottom: 8; }
      appendOutLines(self, outs);
    }
  }
}

// ── 页头 ─────────────────────────────────────────────────────────────────────
container PageHead() {
  bg: cBg; pad: (56, 0, 8, 0);
  WrapCol {
    pad: (0, 24);
    Text("examples · 眼见为实") { font: fMono; size: 12; color: cSignal; letterSpacing: "0.18em"; marginBottom: 16; }
    Text("示例画廊") { size: 44; weight: 900; color: cText; lineHeight: "1.2"; marginBottom: 12; }
    Text("这一页分两块。上半是特性测试样例——语言核心一屏一个概念,模拟控制台里每行输出都是引擎真实跑出来的。下半是展示样例——前端容器语法做出的酷炫页面,点开就在 Playground 里跑,代码就在左边,随便改。") {
      size: 16; color: cDim; maxWidth: "48em"; marginBottom: 8; lineHeight: "1.7";
    }
    Row {
      gap: 12; flexWrap: "wrap"; marginTop: 20;
      append(self, jumpLink("▸ 特性测试样例 · 语言核心", "#features"));
      append(self, jumpLink("▸ 展示样例 · 前端酷炫", "#showcase"));
    }
  }
}

// ── #features:语言核心,一屏一个概念 ───────────────────────────────────────────
container FeatureTests() {
  id: "features"; bg: cBg; pad: (48, 0, 56, 0);
  WrapCol {
    pad: (0, 24);
    Text("console · 引擎真跑") { font: fMono; size: 12; color: cSignal; letterSpacing: "0.18em"; marginBottom: 10; }
    Text("特性测试样例:一屏一个概念") { size: 30; weight: 800; color: cText; marginBottom: 12; lineHeight: "1.3"; }
    Text("语言核心不需要浏览器——下面十个最小可跑片段,覆盖类型、派生 :=、反应式家族(when/changed)、event 委托、group、字符串插值、定点小数、each/break,以及 function 一等类型。点「在 Playground 跑」当场复现。") {
      size: 15; color: cDim; maxWidth: "48em"; marginBottom: 32; lineHeight: "1.7";
    }
    Box {
      display: "grid"; gridTemplateColumns: "repeat(auto-fit, minmax(400px, 1fr))"; gap: 26;
      FeatureCard("变量与类型", "强类型直给:number / string / bool,运算即所见。", "01-types.when", src01, lines01, colors01, out01)
      FeatureCard("派生绑定 :=", "total 持续等于 price + shipping:只改输入,派生值自己变。", "02-derive.when", src02, lines02, colors02, out02)
      FeatureCard("when · 边沿触发", "条件从假变真的那一刻触发一次;持续为真不重复刷屏。", "03-when-edge.when", src03, lines03, colors03, out03)
      FeatureCard("changed · 每变必报", "changed 记流水账,when 只在越线那一下告警——各司其职。", "04-changed.when", src04, lines04, colors04, out04)
      FeatureCard("event 委托", "event<T> 是一等值:emit 触发、with 收参,信号线还能交给函数。", "05-event.when", src05, lines05, colors05, out05)
      FeatureCard("group 数据结构", "数组和哈希表的统一体:数字键走数组,字符串键走哈希。", "06-group.when", src06, lines06, colors06, out06)
      FeatureCard("字符串插值", "\"\${a} * \${b} = \${a * b}\"——表达式直接进字符串。", "07-interp.when", src07, lines07, colors07, out07)
      FeatureCard("定点小数 number<string>", "浮点的 0.1 + 0.2 会漂移;number<string> 精确定点,:2 定标两位小数。", "08-money.when", src08, lines08, colors08, out08)
      FeatureCard("each · break 全量跳出", "each(group) 遍历,break 撞到即刻整体跳出循环。", "09-each.when", src09, lines09, colors09, out09)
      FeatureCard("function 是一等类型", "函数能装进变量再调用——function 是变量类型,不是保留字。", "10-function.when", src10, lines10, colors10, out10)
    }
  }
}

// ── #showcase:前端能做到哪一步 ─────────────────────────────────────────────────
container Showcase() {
  id: "showcase"; bg: cBgDeep; pad: (48, 0, 56, 0);
  WrapCol {
    pad: (0, 24);
    Text("playground · 眼见为实") { font: fMono; size: 12; color: cSignal; letterSpacing: "0.18em"; marginBottom: 10; }
    Text("展示样例:前端能做到哪一步") { size: 30; weight: 800; color: cText; marginBottom: 12; lineHeight: "1.3"; }
    Text("同一门语言,同一套 container 容器语法——没有虚拟 DOM,布局就是 := 电路。每张卡都在 Playground 里当场跑,wasm 引擎、真实 DOM,代码就在左边随便改。") {
      size: 15; color: cDim; maxWidth: "48em"; marginBottom: 32; lineHeight: "1.7";
    }
    append(self, leadCard());
    Box {
      display: "grid"; gridTemplateColumns: "repeat(auto-fit, minmax(260px, 1fr))"; gap: 18;
      append(self, showCard("game.when", "Flappy 金苹果",
        "一个完整的游戏:没有游戏引擎、没有主循环对象、没有一个监听器的注册/解绑。碰撞检测、计分、柱子回收全是扁平的 when 条件;跳跃与物理冻结是代数,不是分支。点击画面拍打苹果。",
        "./playground.html?example=game.when", thumbGame()));
      append(self, showCard("mask.when", "容器蒙版合成",
        "PS 的杀手锏做成一等写法:拿一个容器的形状/明度当另一个容器的蒙版,mask: 某容器。运行时把蒙版容器搬进共享 <mask>,内核零改;文字挖空、圆形开窗都是同一招。",
        "./playground.html?example=mask.when", thumbMask()));
      append(self, showCard("motion.when", "动画编排 · WAAPI",
        "Web Animations API 原语 animate:关键帧和时序都是普通 group,序列化后交给浏览器原生动画引擎——delay 错峰入场,弹簧式缓动回弹。",
        "./playground.html?example=motion.when", thumbMotion()));
      append(self, showCard("clip.when", "剪贴蒙版",
        "P5 剪贴蒙版:底层可见,把上面的层裁到它的形状——写法 clipTo: base,base 用 <use> 活引用留在原地。是真 PS 剪贴组,不是吃掉源的 mask:。",
        "./playground.html?example=clip.when", thumbClip()));
      append(self, showCard("masonry.when", "瀑布流排版",
        "flex/grid 都做不好的事:按每张卡片的实测高度,塞进当前最短的列。measure(card) 拿反应式真实尺寸,父容器与子卡片协商定位——骨灰级自定义排版。",
        "./playground.html?example=masonry.when", thumbMasonry()));
      append(self, showCard("events.when", "富事件跟随",
        "类型即契约:声明 event<group>,DOM 事件的坐标/键码/修饰键就装成 group 喂进来。聚光灯跟鼠标、hover 是反应式状态、键盘面板实时显示按键。",
        "./playground.html?example=events.when", thumbEvents()));
      append(self, showCard("styled.when", "反应式购物车",
        "渐变卡片里点 +/−:命令式只写 qty ± 1 这一件事,总价、颜色、满减徽章全是 := 派生加 changed 反应,自己跟着变。",
        "./playground.html?example=styled.when", thumbStyled()));
      append(self, showCard("switch.when", "路由切换",
        "容器体 switch = 反应式选择器:url 一变,视图自动切到匹配的 case——没有路由库,也不需要。",
        "./playground.html?example=switch.when", thumbSwitch()));
      append(self, showCard("sensing.when", "感知信号 · 自适应网格",
        "自适应布局,不写一句媒体查询:cols 随容器宽度反应式变(>500→4 列,>300→3 列)。ResizeObserver 把宽度写进信号,:= 派生加 changed 让列数和文字全自动跟随。",
        "./playground.html?example=sensing.when", thumbSensing()));
      append(self, showCard("neon.when", "光扫边框 · 图层动效",
        "conic 渐变光层被 mask: ring(2) 裁成 2px 边框环,spin 转动的是渐变角,不是整个盒子——盒子若整体旋转,遮罩会跟着转,视觉会失真。标题文字同理:线性渐变 + clipText + sweep 做出光扫过的效果。",
        "./playground.html?example=neon.when", thumbNeon()));
    }
  }
}

// ── 整页(顶层容器,与 landing.when 同一结构:NavBar → 正文 → Footer)──────────────
container App() {
  font: fSans; bg: cBg; color: cText;
  NavBar()
  PageHead()
  FeatureTests()
  append(self, waveDivider());
  Showcase()
  Footer {
    bg: cBg; borderTop: "1px solid " + cLine; pad: (32, 0, 44, 0);
    WrapRow {
      pad: (0, 24); gap: 20; flexWrap: "wrap"; alignItems: "center";
      Text("© 2026 WhenScript · 写入,即触发") { color: cDim; size: 13; }
      Box { width: fill; minWidth: "20px"; }
      append(self, navLink("联系我们", "./contact.html", false, false));
      append(self, navLink("VS Code Marketplace", "https://marketplace.visualstudio.com/items?itemName=whenscript-lang.whenscript", false, true));
      append(self, navLink("GitHub", "https://github.com/NightPoetry/whenscript", false, true));
    }
  }
}

setStyle(query("body"), "margin", "0");
setStyle(query("body"), "padding", "0");
setStyle(query("body"), "background", cBg);
App();
