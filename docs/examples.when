// ══════════════════════════════════════════════════════════════════════════════
//  WhenScript 示例画廊 —— 用 WhenScript 自己写的。
//
//  浏览器端 .when 不能互相 import(host.js 的 boot() 只接一份完整源码字符串),所以这份文件
//  自包含:设计 token / 导航栏 / 页脚都是从 landing.when 原样搬过来的(颜色值逐字一致,
//  这是全站视觉统一的唯一保证)。写法同样全部来自现有 .when 范例:container 容器语法 +
//  create/setAttr/setStyle/append 手拼真实 DOM/SVG。
//
//  页面分两块:
//   #features —— 语言核心:十个最小可跑片段(模拟控制台样式),代码/输出都是从引擎真实跑出来的
//                 结果誊抄的(这一页本身不重新执行它们——真正会跑的地方是点开 Playground 之后)。
//   #showcase —— 前端展示:一张头牌横幅(blog.when)+ 十张卡片,链接到 Playground 的
//                 ?example=xxx.when 深链。
//
//  ★ neon.when 原本在 examples.html 里是一张「活演示」卡:用 fetch 拿源码、建 iframe、
//  postMessage 把源码喂给 playground-runner.html 实时跑。核对过 dom 模块(Rust/src/core/web/dom.rs)
//  和 host.js 的全部 host_* 桥接后确认:没有 postMessage 桥接原语(全仓库 grep 零命中),
//  dom.on() 能挂 "load" 但引擎侧没有办法主动 postMessage 进 iframe——这条活演示链路在当前
//  运行时原语下无法复现。按任务约定的判断:这不值得为一张卡片新开一个内核工程(违反「该不该动
//  内核」硬门里的"特性特例"红线),所以把这张卡降级成和其余展示卡片完全一样的静态卡片
//  (缩略图 + 标题 + 说明 + 「在 Playground 打开」链接),折进 #showcase 的网格里。
// ══════════════════════════════════════════════════════════════════════════════
import { create, setAttr, setStyle, setText, append, query, Text } from "dom";

// ── 设计 token(与 landing.when / index.html 的 :root 变量逐值一致)──────────────
string cBg     = "#1e1b2e";   // --bg
string cBgDeep = "#171426";   // --bg-deep
string cPanel  = "#26213c";   // --panel
string cLine   = "#3b3358";   // --line
string cText   = "#ece8f8";   // --text
string cDim    = "#a89fc8";   // --dim
string cSignal = "#ffb454";   // --signal 琥珀
string cTrace  = "#6fd9e7";   // --trace  青
string cArrow  = "#ff5fa2";   // --arrow  粉
string cOk     = "#89ca78";   // --ok
string cTerm   = "#14111f";   // --term(本页专属:模拟控制台/live 卡片的深色壳,比 bg-deep 更沉)
string fMono   = "ui-monospace, SFMono-Regular, Menlo, Consolas, monospace";
string fSans   = "system-ui, -apple-system, 'PingFang SC', 'Microsoft YaHei', sans-serif";

// ── 手拼 DOM 原语(与 landing.when 逐字一致)──────────────────────────────────
number navLink(string label, string href, bool active, bool external) {
  number a = create("a");
  setText(a, label);
  setAttr(a, "href", href);
  if (external) { setAttr(a, "target", "_blank"); setAttr(a, "rel", "noopener"); }
  setStyle(a, "font-size", "14px");
  setStyle(a, "font-weight", "500");
  setStyle(a, "text-decoration", "none");
  setStyle(a, "padding", "4px 2px");
  setStyle(a, "border-bottom", "2px solid transparent");
  if (active) {
    setStyle(a, "color", cText);
    setStyle(a, "border-bottom", "2px solid " + cSignal);
  } else {
    setStyle(a, "color", cDim);
  }
  return a;
}

number navCta(string label, string href) {
  number a = create("a");
  setText(a, label);
  setAttr(a, "href", href); setAttr(a, "target", "_blank"); setAttr(a, "rel", "noopener");
  setStyle(a, "color", cSignal); setStyle(a, "font-size", "14px"); setStyle(a, "font-weight", "600"); setStyle(a, "text-decoration", "none");
  return a;
}

number ctaLink(string label, string href, bool primary) {
  number a = create("a");
  setText(a, label);
  setAttr(a, "href", href);
  setStyle(a, "display", "inline-block");
  setStyle(a, "padding", "12px 22px");
  setStyle(a, "border-radius", "10px");
  setStyle(a, "font-size", "15px");
  setStyle(a, "font-weight", "600");
  setStyle(a, "text-decoration", "none");
  if (primary) {
    setStyle(a, "background", cSignal);
    setStyle(a, "color", "#241c0a");
    setStyle(a, "border", "1px solid " + cSignal);
  } else {
    setStyle(a, "background", "transparent");
    setStyle(a, "color", cText);
    setStyle(a, "border", "1px solid " + cLine);
  }
  return a;
}

number brandMark() {
  number svg = create("svg");
  setAttr(svg, "width", "26"); setAttr(svg, "height", "26"); setAttr(svg, "viewBox", "0 0 26 26");
  number rect = create("rect");
  setAttr(rect, "width", "26"); setAttr(rect, "height", "26"); setAttr(rect, "rx", "6"); setAttr(rect, "fill", cBgDeep);
  append(svg, rect);
  number path = create("path");
  setAttr(path, "d", "M4 17 H8 V9 H13 V17 H18 V9 H22");
  setAttr(path, "fill", "none"); setAttr(path, "stroke", cSignal);
  setAttr(path, "stroke-width", "2"); setAttr(path, "stroke-linecap", "round"); setAttr(path, "stroke-linejoin", "round");
  append(svg, path);
  return svg;
}

number brandLink() {
  number a = create("a");
  setAttr(a, "href", "./index.html");
  setStyle(a, "display", "flex"); setStyle(a, "align-items", "center"); setStyle(a, "gap", "10px"); setStyle(a, "text-decoration", "none");
  append(a, brandMark());
  number t = create("span");
  setText(t, "WhenScript");
  setStyle(t, "font-weight", "700"); setStyle(t, "font-size", "17px"); setStyle(t, "color", cText);
  append(a, t);
  return a;
}

// 代码行:一行等宽、保留缩进的代码(white-space:pre)。col 决定这一行的颜色(默认 cText,
// 注释 cDim,含 := 的反应式派生行 cTrace)—— 与 landing.when 逐字一致,复用做「输出」行同款底色。
number codeLine(string txt, string col) {
  number d = create("div");
  setText(d, txt);
  setStyle(d, "font-family", fMono);
  setStyle(d, "font-size", "12.5px");
  setStyle(d, "line-height", "1.75");
  setStyle(d, "color", col);
  setStyle(d, "white-space", "pre");
  return d;
}

// ★ 引擎坑(本页开发时发现,未见文档记载):`each(group) with(key, value)` 双参数形式,直接写在
// container 语句体里会静默失效——两个绑定变量在 body 内读出来全是 unknown(SSR 输出可见
// 一整块 "unknown" 文本/"color:unknown")。单参数 `with(value)` 形式在 container 体里没问题
// (blog.when/masonry.when 的 each 都是单参数,没踩到这个坑)。用 whenscript ssr 跑最小复现
// 确认:同一个双参数 each 挪进普通 number 函数体(不在 container 语句体里)就完全正常。这是
// 页面内容任务,不是改内核的场合(该不该动内核硬门:值不值得为一张页面开一次内核工程),所以
// 这里绕开——双参数 each 一律搬进下面这两个普通函数,container 体内只 append 调用结果。
number appendCodeLines(number parent, group lines, group colors) {
  each(lines) with(idx, line) { append(parent, codeLine(line, colors[idx])); }
  return parent;
}
number appendOutLines(number parent, group outs) {
  each(outs) with(idx, line) { append(parent, codeLine("› " + line, cOk)); }
  return parent;
}

// jump-row 的胶囊小链接(页头两个锚点:跳 #features / #showcase)。
number jumpLink(string label, string href) {
  number a = create("a");
  setText(a, label);
  setAttr(a, "href", href);
  setStyle(a, "font-family", fMono); setStyle(a, "font-size", "12px"); setStyle(a, "letter-spacing", "0.06em");
  setStyle(a, "color", cDim); setStyle(a, "border", "1px solid " + cLine); setStyle(a, "border-radius", "999px");
  setStyle(a, "padding", "8px 14px"); setStyle(a, "background", cBgDeep); setStyle(a, "text-decoration", "none");
  return a;
}

// 模拟控制台卡头里那个「▶ 在 Playground 跑」小按钮(靠右对齐)。
number playRunLink(string href) {
  number a = create("a");
  setText(a, "▶ 在 Playground 跑");
  setAttr(a, "href", href);
  setStyle(a, "margin-left", "auto"); setStyle(a, "font-family", fMono); setStyle(a, "font-size", "11px");
  setStyle(a, "font-weight", "700"); setStyle(a, "color", cSignal); setStyle(a, "border", "1px solid " + cLine);
  setStyle(a, "border-radius", "6px"); setStyle(a, "padding", "5px 9px"); setStyle(a, "text-decoration", "none");
  setStyle(a, "white-space", "nowrap");
  return a;
}

// ── 居中内容列(对照 index.html 的 .wrap:max-width:1080px; margin:0 auto)────────
container WrapRow() extends Row {
  width: fill; maxWidth: "1080px"; margin: "0 auto"; alignItems: "center";
}
container WrapCol() extends Column {
  width: fill; maxWidth: "1080px"; margin: "0 auto";
}

// ── 顶部导航(与 landing.when 逐字一致,只把「示例」的 active 改成 true)───────────
container NavBar() {
  bg: cBg; borderBottom: "1px solid " + cLine; position: "sticky"; top: 0; zIndex: "20"; backdropFilter: "blur(10px)";
  WrapRow {
    gap: 22; pad: (0, 24); height: 58; flexWrap: "wrap";
    append(self, brandLink());
    Row {
      marginLeft: "auto"; gap: 18; alignItems: "center"; flexWrap: "wrap";
      append(self, navLink("Playground", "./playground.html", false, false));
      append(self, navLink("示例", "./examples.html", true, false));
      append(self, navLink("文档", "./docs.html", false, false));
      append(self, navLink("联系", "./contact.html", false, false));
      append(self, navCta("VS Code 扩展", "https://marketplace.visualstudio.com/items?itemName=whenscript-lang.whenscript"));
      append(self, navLink("GitHub", "https://github.com/NightPoetry/whenscript", false, true));
    }
  }
}

// 方波分割线(与 landing.when 逐字一致):两个板块之间的信号方波,持续向左滚动。
number waveDivider() {
  number svg = create("svg");
  setAttr(svg, "viewBox", "0 0 1200 24"); setAttr(svg, "preserveAspectRatio", "none");
  setStyle(svg, "display", "block"); setStyle(svg, "width", "100%"); setStyle(svg, "height", "24px"); setStyle(svg, "opacity", "0.5");

  number defs = create("defs");
  append(svg, defs);
  number pattern = create("pattern");
  setAttr(pattern, "id", "waveTile");
  setAttr(pattern, "width", "60"); setAttr(pattern, "height", "24"); setAttr(pattern, "patternUnits", "userSpaceOnUse");
  append(defs, pattern);
  number tile = create("path");
  setAttr(tile, "d", "M0 18 H30 V6 H60");
  setAttr(tile, "fill", "none"); setAttr(tile, "stroke", cSignal); setAttr(tile, "stroke-width", "1.5");
  append(pattern, tile);

  number rect = create("rect");
  setAttr(rect, "x", "0"); setAttr(rect, "y", "0"); setAttr(rect, "width", "200%"); setAttr(rect, "height", "24");
  setAttr(rect, "fill", "url(#waveTile)");
  append(svg, rect);

  return svg;
}

// ══════════════════════════════════════════════════════════════════════════════
//  缩略图专用最小 SVG 图元 helper —— 坐标/尺寸一律按字符串传(直接对应 setAttr 的字符串
//  参数,不做数值转换)。每个 helper 只管最常见的必填属性,其余(rx/opacity/stroke-dasharray
//  之类)由调用处拿着返回的元素 id 继续 setAttr 补,避免为每种变体都写一个新 helper。
// ══════════════════════════════════════════════════════════════════════════════
number thumbSvg() {
  number svg = create("svg");
  setAttr(svg, "viewBox", "0 0 120 60");
  setAttr(svg, "preserveAspectRatio", "xMidYMid meet");
  return svg;
}
number svgRect(number parent, string x, string y, string w, string h, string fill) {
  number r = create("rect");
  setAttr(r, "x", x); setAttr(r, "y", y); setAttr(r, "width", w); setAttr(r, "height", h); setAttr(r, "fill", fill);
  append(parent, r);
  return r;
}
number svgBg(number parent, string fill) {
  return svgRect(parent, "0", "0", "120", "60", fill);
}
number svgCircle(number parent, string cx, string cy, string r, string fill) {
  number c = create("circle");
  setAttr(c, "cx", cx); setAttr(c, "cy", cy); setAttr(c, "r", r); setAttr(c, "fill", fill);
  append(parent, c);
  return c;
}
number svgPath(number parent, string d, string fill, string stroke, string sw) {
  number p = create("path");
  setAttr(p, "d", d); setAttr(p, "fill", fill);
  if (stroke != "") { setAttr(p, "stroke", stroke); setAttr(p, "stroke-width", sw); }
  append(parent, p);
  return p;
}
number svgText(number parent, string x, string y, string content, string size, string fill) {
  number t = create("text");
  setAttr(t, "x", x); setAttr(t, "y", y); setAttr(t, "font-size", size); setAttr(t, "fill", fill);
  setAttr(t, "text-anchor", "middle"); setAttr(t, "font-family", "monospace"); setAttr(t, "font-weight", "900");
  setText(t, content);
  append(parent, t);
  return t;
}

// ── 十张展示卡片的缩略图(照抄 examples.html 里每张卡片内嵌的手绘 SVG,坐标/颜色逐点一致)──

number thumbGame() {
  number svg = thumbSvg();
  svgBg(svg, "#0e1630");
  svgRect(svg, "22", "0", "16", "20", "#2f7d4f");
  svgRect(svg, "22", "40", "16", "20", "#2f7d4f");
  svgRect(svg, "82", "0", "16", "14", "#2f7d4f");
  svgRect(svg, "82", "34", "16", "26", "#2f7d4f");
  svgCircle(svg, "60", "30", "7", "#ffb454");
  svgPath(svg, "M60 23 q3 -4 6 -2", "none", "#89ca78", "2");
  return svg;
}

number thumbMask() {
  number svg = thumbSvg();
  number defs = create("defs"); append(svg, defs);
  number grad = create("linearGradient");
  setAttr(grad, "id", "mg"); setAttr(grad, "x1", "0"); setAttr(grad, "y1", "0"); setAttr(grad, "x2", "1"); setAttr(grad, "y2", "1");
  append(defs, grad);
  number s1 = create("stop"); setAttr(s1, "offset", "0"); setAttr(s1, "stop-color", "#6fd9e7"); append(grad, s1);
  number s2 = create("stop"); setAttr(s2, "offset", "1"); setAttr(s2, "stop-color", "#ff5fa2"); append(grad, s2);
  number mask = create("mask"); setAttr(mask, "id", "mm"); append(defs, mask);
  svgText(mask, "60", "42", "W", "34", "#fff");
  svgBg(svg, "#14111f");
  number panel = svgRect(svg, "10", "6", "100", "48", "url(#mg)");
  setAttr(panel, "mask", "url(#mm)");
  return svg;
}

number thumbMotion() {
  number svg = thumbSvg();
  svgBg(svg, "#1a1530");
  svgCircle(svg, "24", "46", "6", "#6fd9e7");
  svgCircle(svg, "48", "34", "6", "#ffb454");
  svgCircle(svg, "72", "24", "6", "#ff5fa2");
  svgCircle(svg, "96", "16", "6", "#89ca78");
  number path = svgPath(svg, "M24 46 Q48 10 96 16", "none", "#a89fc8", "1.5");
  setAttr(path, "opacity", ".5"); setAttr(path, "stroke-dasharray", "3 3");
  return svg;
}

number thumbClip() {
  number svg = thumbSvg();
  number defs = create("defs"); append(svg, defs);
  number cp = create("clipPath"); setAttr(cp, "id", "cs"); append(defs, cp);
  number poly1 = create("polygon");
  setAttr(poly1, "points", "60,6 71,34 100,34 76,50 84,54 60,42 36,54 44,50 20,34 49,34");
  append(cp, poly1);
  svgBg(svg, "#0f172a");
  number poly2 = create("polygon");
  setAttr(poly2, "points", "60,6 71,34 100,34 76,50 84,54 60,42 36,54 44,50 20,34 49,34");
  setAttr(poly2, "fill", "#1e293b");
  append(svg, poly2);
  number g = create("g"); setAttr(g, "clip-path", "url(#cs)"); append(svg, g);
  svgRect(g, "0", "0", "120", "60", "#6fd9e7");
  svgRect(g, "0", "30", "120", "30", "#ff5fa2");
  return svg;
}

number thumbMasonry() {
  number svg = thumbSvg();
  svgBg(svg, "#171426");
  number a1 = svgRect(svg, "8", "8", "32", "20", "#6fd9e7"); setAttr(a1, "rx", "3"); setAttr(a1, "opacity", ".85");
  number a2 = svgRect(svg, "8", "32", "32", "20", "#6fd9e7"); setAttr(a2, "rx", "3"); setAttr(a2, "opacity", ".5");
  number b1 = svgRect(svg, "44", "8", "32", "34", "#ffb454"); setAttr(b1, "rx", "3"); setAttr(b1, "opacity", ".85");
  number b2 = svgRect(svg, "44", "46", "32", "8", "#ffb454"); setAttr(b2, "rx", "3"); setAttr(b2, "opacity", ".5");
  number c1 = svgRect(svg, "80", "8", "32", "14", "#ff5fa2"); setAttr(c1, "rx", "3"); setAttr(c1, "opacity", ".85");
  number c2 = svgRect(svg, "80", "26", "32", "26", "#ff5fa2"); setAttr(c2, "rx", "3"); setAttr(c2, "opacity", ".5");
  return svg;
}

number thumbEvents() {
  number svg = thumbSvg();
  svgBg(svg, "#12101d");
  number halo = svgCircle(svg, "72", "30", "26", "#ffb454"); setAttr(halo, "opacity", ".18");
  number core = svgCircle(svg, "72", "30", "12", "#ffb454"); setAttr(core, "opacity", ".35");
  svgPath(svg, "M60 24 L60 46 L66 40 L70 48 L74 46 L70 38 L78 38 Z", "#ece8f8", "", "0");
  return svg;
}

number thumbStyled() {
  number svg = thumbSvg();
  number defs = create("defs"); append(svg, defs);
  number grad = create("linearGradient");
  setAttr(grad, "id", "sg"); setAttr(grad, "x1", "0"); setAttr(grad, "y1", "0"); setAttr(grad, "x2", "1"); setAttr(grad, "y2", "1");
  append(defs, grad);
  number s1 = create("stop"); setAttr(s1, "offset", "0"); setAttr(s1, "stop-color", "#ff6bcb"); append(grad, s1);
  number s2 = create("stop"); setAttr(s2, "offset", "1"); setAttr(s2, "stop-color", "#6d5dfc"); append(grad, s2);
  svgBg(svg, "#171426");
  number panel = svgRect(svg, "18", "12", "84", "36", "url(#sg)"); setAttr(panel, "rx", "8");
  number c1 = svgCircle(svg, "34", "30", "7", "#fff"); setAttr(c1, "opacity", ".9");
  svgText(svg, "34", "34", "−", "10", "#6d5dfc");
  number c2 = svgCircle(svg, "86", "30", "7", "#fff"); setAttr(c2, "opacity", ".9");
  svgText(svg, "86", "34", "+", "10", "#6d5dfc");
  number qty = svgRect(svg, "52", "25", "16", "10", "#fff"); setAttr(qty, "rx", "2"); setAttr(qty, "opacity", ".95");
  return svg;
}

number thumbSwitch() {
  number svg = thumbSvg();
  svgBg(svg, "#171426");
  number t1 = svgRect(svg, "14", "10", "30", "10", "#6fd9e7"); setAttr(t1, "rx", "5");
  number t2 = svgRect(svg, "48", "10", "30", "10", "#3b3358"); setAttr(t2, "rx", "5");
  number t3 = svgRect(svg, "82", "10", "24", "10", "#3b3358"); setAttr(t3, "rx", "5");
  number panel = svgRect(svg, "14", "28", "92", "24", "#26213c"); setAttr(panel, "rx", "6"); setAttr(panel, "stroke", "#6fd9e7");
  number l1 = svgRect(svg, "22", "36", "40", "6", "#ffb454"); setAttr(l1, "rx", "3");
  number l2 = svgRect(svg, "22", "45", "60", "4", "#a89fc8"); setAttr(l2, "rx", "2"); setAttr(l2, "opacity", ".6");
  return svg;
}

number thumbSensing() {
  number svg = thumbSvg();
  svgBg(svg, "#eef2ff");
  number g1 = svgRect(svg, "10", "10", "20", "16", "#3a55d8"); setAttr(g1, "rx", "3");
  number g2 = svgRect(svg, "34", "10", "20", "16", "#3a55d8"); setAttr(g2, "rx", "3");
  number g3 = svgRect(svg, "58", "10", "20", "16", "#3a55d8"); setAttr(g3, "rx", "3");
  number g4 = svgRect(svg, "82", "10", "20", "16", "#6fd9e7"); setAttr(g4, "rx", "3");
  number w1 = svgRect(svg, "10", "34", "43", "16", "#c9d4ff"); setAttr(w1, "rx", "3");
  number w2 = svgRect(svg, "57", "34", "45", "16", "#c9d4ff"); setAttr(w2, "rx", "3");
  svgPath(svg, "M104 44 h8 m0 0 l-3 -3 m3 3 l-3 3", "none", "#3a55d8", "1.5");
  return svg;
}

// neon.when 缩略图是新画的(原来那张是活 iframe,没有静态图):两段弧线抽象出「conic 渐变
// 光环被 mask 裁成一圈边框」的意象,青/粉两色对照原版 NeonCard 的 cyan/magenta。
number thumbNeon() {
  number svg = thumbSvg();
  svgBg(svg, "#111111");
  number a1 = svgPath(svg, "M60 10 A20 20 0 0 1 80 30", "none", "#6fd9e7", "4"); setAttr(a1, "stroke-linecap", "round");
  number a2 = svgPath(svg, "M80 30 A20 20 0 0 1 60 50", "none", "#ff5fa2", "4"); setAttr(a2, "stroke-linecap", "round");
  number a3 = svgPath(svg, "M60 50 A20 20 0 0 1 40 30", "none", "#6fd9e7", "4"); setAttr(a3, "stroke-linecap", "round");
  number a4 = svgPath(svg, "M40 30 A20 20 0 0 1 60 10", "none", "#ff5fa2", "4"); setAttr(a4, "stroke-linecap", "round");
  svgText(svg, "60", "34", "W", "16", "#ffffff");
  return svg;
}

// 头牌横幅(blog.when)专属缩略图,230x150 视窗,坐标照抄 examples.html 的 .lead-thumb。
number leadThumb() {
  number svg = create("svg");
  setAttr(svg, "width", "230"); setAttr(svg, "height", "150"); setAttr(svg, "viewBox", "0 0 230 150"); setAttr(svg, "fill", "none");
  number frame = svgRect(svg, "1", "1", "228", "148", "#171426"); setAttr(frame, "rx", "12"); setAttr(frame, "stroke", "#3b3358");
  number halo = svgCircle(svg, "42", "42", "22", "none"); setAttr(halo, "stroke", "#ffb454"); setAttr(halo, "stroke-width", "2"); setAttr(halo, "opacity", ".9");
  number ring = svgCircle(svg, "42", "42", "15", "#26213c"); setAttr(ring, "stroke", "#6fd9e7"); setAttr(ring, "stroke-width", "1.5");
  svgCircle(svg, "42", "42", "6", "#ffb454");
  number t1 = svgRect(svg, "76", "30", "120", "9", "#ece8f8"); setAttr(t1, "rx", "4.5"); setAttr(t1, "opacity", ".85");
  number t2 = svgRect(svg, "76", "46", "80", "7", "#a89fc8"); setAttr(t2, "rx", "3.5"); setAttr(t2, "opacity", ".6");
  number prog = svgCircle(svg, "196", "42", "14", "none"); setAttr(prog, "stroke", "#3b3358"); setAttr(prog, "stroke-width", "3");
  number arc = svgPath(svg, "M196 28 a14 14 0 0 1 12 21", "none", "#6fd9e7", "3"); setAttr(arc, "stroke-linecap", "round");
  number card1 = svgRect(svg, "18", "78", "94", "40", "#26213c"); setAttr(card1, "rx", "7"); setAttr(card1, "stroke", "#3b3358");
  number card2 = svgRect(svg, "118", "78", "94", "40", "#26213c"); setAttr(card2, "rx", "7"); setAttr(card2, "stroke", "#3b3358");
  number l1 = svgRect(svg, "28", "88", "60", "6", "#ffb454"); setAttr(l1, "rx", "3"); setAttr(l1, "opacity", ".8");
  number l2 = svgRect(svg, "28", "100", "72", "5", "#a89fc8"); setAttr(l2, "rx", "2.5"); setAttr(l2, "opacity", ".5");
  number l3 = svgRect(svg, "128", "88", "54", "6", "#ff5fa2"); setAttr(l3, "rx", "3"); setAttr(l3, "opacity", ".8");
  number l4 = svgRect(svg, "128", "100", "70", "5", "#a89fc8"); setAttr(l4, "rx", "2.5"); setAttr(l4, "opacity", ".5");
  number wave = svgPath(svg, "M14 134 H36 V128 H58 V134 H80 V128 H102 V134 H124 V128 H146 V134 H168 V128 H190 V134 H214", "none", "#ffb454", "1.5");
  setAttr(wave, "opacity", ".7");
  return svg;
}

// ── 展示卡片:整卡是一个真 <a>,内部手拼缩略图/文件徽章/标题/说明/跳转提示 —— 对照 examples.html
// 的 .show-card(九张原有卡片 + 降级后的 neon.when,一共十张,结构完全一样)。
number showCard(string file, string title, string desc, string href, number thumb) {
  number a = create("a");
  setAttr(a, "href", href);
  setStyle(a, "display", "flex"); setStyle(a, "flex-direction", "column"); setStyle(a, "gap", "8px");
  setStyle(a, "background", cPanel); setStyle(a, "border", "1px solid " + cLine); setStyle(a, "border-radius", "12px");
  setStyle(a, "padding", "22px"); setStyle(a, "color", cText); setStyle(a, "text-decoration", "none");

  number thumbBox = create("div");
  setStyle(thumbBox, "display", "block"); setStyle(thumbBox, "width", "100%"); setStyle(thumbBox, "height", "88px");
  setStyle(thumbBox, "border-radius", "9px"); setStyle(thumbBox, "margin-bottom", "4px");
  setStyle(thumbBox, "border", "1px solid " + cLine); setStyle(thumbBox, "overflow", "hidden"); setStyle(thumbBox, "background", cBgDeep);
  append(thumbBox, thumb);
  append(a, thumbBox);

  number badge = create("span");
  setText(badge, file);
  setStyle(badge, "font-family", fMono); setStyle(badge, "font-size", "11px"); setStyle(badge, "letter-spacing", "0.1em");
  setStyle(badge, "color", cSignal); setStyle(badge, "border", "1px solid " + cLine); setStyle(badge, "border-radius", "999px");
  setStyle(badge, "padding", "5px 10px"); setStyle(badge, "background", cBgDeep); setStyle(badge, "align-self", "flex-start");
  append(a, badge);

  number h = create("h3");
  setText(h, title);
  setStyle(h, "margin", "6px 0 0"); setStyle(h, "font-size", "18px"); setStyle(h, "color", cText);
  append(a, h);

  number p = create("p");
  setText(p, desc);
  setStyle(p, "margin", "0"); setStyle(p, "font-size", "13.5px"); setStyle(p, "color", cDim); setStyle(p, "flex", "1 1 auto"); setStyle(p, "line-height", "1.6");
  append(a, p);

  number go = create("span");
  setText(go, "在 Playground 打开 →");
  setStyle(go, "font-size", "13px"); setStyle(go, "font-weight", "600"); setStyle(go, "color", cTrace);
  append(a, go);

  return a;
}

// 头牌横幅(blog.when):整卡是 <a>,左文右图两栏 —— 对照 examples.html 的 .show-lead。
number leadCard() {
  number a = create("a");
  setAttr(a, "href", "./playground.html?example=blog.when");
  setStyle(a, "display", "flex"); setStyle(a, "gap", "26px"); setStyle(a, "align-items", "center"); setStyle(a, "flex-wrap", "wrap");
  setStyle(a, "background", "linear-gradient(150deg, " + cPanel + ", " + cBgDeep + ")");
  setStyle(a, "border", "1px solid " + cLine); setStyle(a, "border-radius", "14px");
  setStyle(a, "padding", "30px"); setStyle(a, "color", cText); setStyle(a, "margin-bottom", "24px");
  setStyle(a, "text-decoration", "none");

  number body = create("div");
  setStyle(body, "flex", "1 1 320px"); setStyle(body, "min-width", "0");

  number badge = create("span");
  setText(badge, "blog.when · 头牌");
  setStyle(badge, "font-family", fMono); setStyle(badge, "font-size", "11px"); setStyle(badge, "letter-spacing", "0.1em");
  setStyle(badge, "color", cSignal); setStyle(badge, "border", "1px solid " + cLine); setStyle(badge, "border-radius", "999px");
  setStyle(badge, "padding", "5px 10px"); setStyle(badge, "background", cBgDeep); setStyle(badge, "display", "inline-block");
  append(body, badge);

  number h = create("h3");
  setText(h, "个人博客 · 前端语法综合演示");
  setStyle(h, "margin", "8px 0 6px"); setStyle(h, "font-size", "25px"); setStyle(h, "color", cText);
  append(body, h);

  number p = create("p");
  setText(p, "一份 .when 长成一整套博客门面:头像光晕、技能环形进度条、页脚波浪分割线——全是真 svg/circle/path,由 create/setAttr/append 手拼,零新语法。在线照片走 Image(url) 真实加载,不是本地占位图。这是「前端也只是插件」最完整的证明。");
  setStyle(p, "margin", "0"); setStyle(p, "color", cDim); setStyle(p, "font-size", "14.5px"); setStyle(p, "max-width", "42em"); setStyle(p, "line-height", "1.7");
  append(body, p);

  number go = create("span");
  setText(go, "在 Playground 打开 →");
  setStyle(go, "display", "block"); setStyle(go, "margin-top", "12px"); setStyle(go, "font-size", "13px"); setStyle(go, "font-weight", "600"); setStyle(go, "color", cTrace);
  append(body, go);

  append(a, body);

  number thumbWrap = create("div");
  setStyle(thumbWrap, "flex", "0 0 auto");
  append(thumbWrap, leadThumb());
  append(a, thumbWrap);

  return a;
}

// ══════════════════════════════════════════════════════════════════════════════
//  十个语言核心特性片段:代码/输出都是从 examples.html 原样誊抄(那边的输出是引擎真实跑出来
//  的结果)。lines/colors 两个平行 group 靠 each(...) with(idx, line) 的索引对齐取色——
//  默认 cText,注释行 cDim,含 := 的派生行 cTrace,和 landing.when LiveCard 的取色规则一致。
//
//  ★ 07-interp 这组的代码文本里,${name}/${a}/${b}/${a * b} 是要"原样显示"的字面文本,不是
//  真的要在本页插值——所以全部写成 \${...} 转义,否则会被 WhenScript 的字符串插值当场求值,
//  在页面上显示出这个作用域里根本不存在的变量值(踩过的坑,见 landing.when 同款注释)。
// ══════════════════════════════════════════════════════════════════════════════

group lines01 = [
  "import { print } from \"console\";",
  "number a = 10;",
  "number b = 3;",
  "string lang = \"WhenScript\";",
  "bool strict = true;",
  "",
  "print(lang, \" 是强类型的: \", strict);",
  "print(\"a + b = \", a + b);",
  "print(\"a / b = \", a / b);",
  "print(\"a > b: \", a > b);"
];
group colors01 = [cText, cText, cText, cText, cText, cDim, cText, cText, cText, cText];
group out01 = [
  "WhenScript 是强类型的: true",
  "a + b = 13",
